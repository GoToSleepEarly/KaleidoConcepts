DATABASE_URL="postgresql://user:password@localhost:5432/pbl_studio?schema=public"
SESSION_SECRET="replace-with-a-long-random-secret"
# DeepSeek 作为备用模型；未配置 QUICKROUTER_API_KEY 时使用
DEEPSEEK_API_KEY="replace-with-deepseek-api-key"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
# QuickRouter (GPT-5.5) 为默认推荐模型，速度更快质量更高
QUICKROUTER_API_KEY="replace-with-quickrouter-api-key"
QUICKROUTER_RESPONSES_MODEL="gpt-5.5"
QUICKROUTER_LESSON_MODEL="gpt-5.5"
QUICKROUTER_IMAGE_MODEL="gpt-image-2"
QUICKROUTER_IMAGE_QUALITY="low"
IMAGE_SUBMITTING_TIMEOUT_MS="900000"
# QuickRouter 生图请求超时；超过后中止 fetch 并回收状态，默认 10 分钟
IMAGE_GENERATION_TIMEOUT_MS="600000"
# 下载生图结果的超时，默认 60 秒
IMAGE_DOWNLOAD_TIMEOUT_MS="60000"
# 落盘前将 provider 返回的 PNG 转码为 WebP 的质量（1-100），默认 78
COURSE_IMAGE_WEBP_QUALITY="78"
AI_REQUEST_TIMEOUT="60000"
IMAGE_GENERATION_CONCURRENCY="2"
MAX_RETRY_PER_IMAGE="2"
BUILD_STALE_MINUTES="5"
PROMPT_VERSION="mvp-v1"
STORAGE_DIR="./storage/images"
