generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Person {
  id           String          @id @default(cuid())
  role         PersonRole
  name         String
  chineseName  String?
  englishName  String?
  age          Int?
  gender       Gender?
  appearance   String?
  interests    String[]
  learningGoal String?
  notes        String?
  avatarUrl    String?
  archivedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  courses      CoursePerson[]
}

model Course {
  id              String          @id @default(cuid())
  title           String
  englishLevel    EnglishLevel
  durationMinutes Int             @default(45)
  theme           String
  grammar         String[]
  storyIdeaMode   StoryIdeaMode   @default(ai)
  storyIdea       String?
  selectedStoryOptionId String?
  status          CourseStatus    @default(draft)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  people          CoursePerson[]
  storyOptions    CourseStoryOption[]
  lessonDraft     CourseLessonDraft?
  resourcePlan    CourseResourcePlan?
  images          CourseImage[]
}

model CoursePerson {
  courseId String
  personId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@id([courseId, personId])
}

model CourseStoryOption {
  id        String
  courseId  String
  variant   String
  title     String
  storyline String
  chapters  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([courseId, id])
  @@index([courseId])
}

model CourseLessonDraft {
  courseId            String   @id
  sourceStoryOptionId String
  content             Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  course              Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseResourcePlan {
  courseId              String   @id
  plan                  Json
  version               Int      @default(1)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  course                Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseImage {
  id               String              @id @default(cuid())
  courseId         String
  chapterId        String?
  shotId           String
  slotId           String
  slotType         CourseImageSlotType
  slotIndex        Int
  sourceParagraphId String?
  sourceExcerpt    String             @default("")
  prompt           String
  promptVersion    String             @default("step4-resource-plan-v1")
  referenceImageIds Json              @default("[]")
  width            Int                @default(1280)
  height           Int                @default(720)
  format           String             @default("webp")
  sourceHash       String
  status           CourseImageStatus
  provider         CourseImageProvider
  providerTaskId   String?
  providerImageUrl String?
  storagePath      String?
  publicUrl        String?
  failureReason    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  course           Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, slotId])
  @@index([courseId, status])
}

enum PersonRole {
  student
  teacher
}

enum Gender {
  male
  female
}

enum EnglishLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum StoryIdeaMode {
  manual
  ai
}

enum CourseStatus {
  draft
  building_resources
  ready
  build_failed
}

enum CourseImageStatus {
  pending
  submitting
  generating
  succeeded
  failed
}

enum CourseImageSlotType {
  visual_cover
  lesson_shot
}

enum CourseImageProvider {
  tencent_hunyuan
}
