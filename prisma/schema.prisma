generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseStatus {
  draft
  generating_options
  options_ready
  generating_lesson
  lesson_ready
  building_resources
  build_failed
  ready
  archived
}

enum ImageStatus {
  pending
  generating
  succeeded
  failed
}

enum AiResourceType {
  story_options
  lesson_text
  normalize
  visual_style
  image
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Student {
  id          String    @id @default(uuid())
  name        String
  age         String?
  grade       String?
  interests   String
  personality String?
  notes       String?
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  courses     Course[]

  @@map("students")
}

model Course {
  id                  String       @id @default(uuid())
  studentId           String?      @map("student_id")
  student             Student?     @relation(fields: [studentId], references: [id])
  status              CourseStatus @default(draft)
  meta                Json
  storyOptions        Json?        @map("story_options")
  selectedStoryOption Json?        @map("selected_story_option")
  lessonText          String?      @map("lesson_text")
  structuredLesson    Json?        @map("structured_lesson")
  visualStyleGuide    String?      @map("visual_style_guide")
  buildStartedAt      DateTime?    @map("build_started_at")
  buildUpdatedAt      DateTime?    @map("build_updated_at")
  archivedAt          DateTime?    @map("archived_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  images              CourseImage[]
  aiUsageLogs         AiUsageLog[]

  @@map("courses")
}

model CourseImage {
  id               String      @id @default(uuid())
  courseId         String      @map("course_id")
  course           Course      @relation(fields: [courseId], references: [id])
  sectionId        String      @map("section_id")
  slotId           String      @map("slot_id")
  slotIndex        Int         @map("slot_index")
  sourceHash       String      @map("source_hash")
  prompt           String
  status           ImageStatus @default(pending)
  url              String?
  filePath         String?     @map("file_path")
  errorCode        String?     @map("error_code")
  errorMessage     String?     @map("error_message")
  attemptCount     Int         @default(0) @map("attempt_count")
  lastGenerationAt DateTime?   @map("last_generation_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@unique([courseId, slotId])
  @@map("course_images")
}

model AiUsageLog {
  id            String         @id @default(uuid())
  courseId      String?        @map("course_id")
  course        Course?        @relation(fields: [courseId], references: [id])
  resourceType  AiResourceType @map("resource_type")
  resourceId    String?        @map("resource_id")
  provider      String?
  model         String?
  promptVersion String?        @map("prompt_version")
  inputTokens   Int?           @map("input_tokens")
  outputTokens  Int?           @map("output_tokens")
  imageCount    Int?           @map("image_count")
  estimatedCost Decimal?       @map("estimated_cost")
  status        String
  errorCode     String?        @map("error_code")
  createdAt     DateTime       @default(now()) @map("created_at")

  @@map("ai_usage_logs")
}
